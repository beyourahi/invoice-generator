{
	"name": "invoice-generator",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --open",
		"build": "vite build",
		"preview": "bun run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"db:check": "drizzle-kit check",
		"db:migrate": "wrangler d1 migrations apply invoice_generator --remote",
		"db:migrate:local": "wrangler d1 migrations apply invoice_generator --local",
		"db:migrate:list": "wrangler d1 migrations list invoice_generator --local"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260504.1",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.6.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "0.31.10",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.10",
		"wrangler": "^4.87.0"
	},
	"dependencies": {
		"better-auth": "^1.6.9",
		"drizzle-orm": "^0.45.2",
		"fflate": "^0.8.2",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"svelte-sonner": "^1.1.1",
		"zod": "^4.4.3"
	}
}
