{
	"name": "invoice-generator",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "rm -rf node_modules/ .wrangler/ .svelte-kit/ bundled/ && bun install && bun cf-typegen && bun format && vite dev --open --host",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --assets .svelte-kit/cloudflare",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.12.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.6.0",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"wrangler": "^4.86.0"
	},
	"dependencies": {
		"fflate": "^0.8.2",
		"gsap": "^3.15.0",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1"
	}
}
